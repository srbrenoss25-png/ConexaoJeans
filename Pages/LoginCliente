<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - ConexãoJeans</title>
    <link rel="stylesheet" href="./CSS/login.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400&display=swap" rel="stylesheet">
    <script src="./javascript/login.js"></script>
</head>
<body>
    <div class="login-wrapper">
        <div class="logo">
            <img src="IMG/logo.png" alt="Logo ConexaoJeans">
        </div>
    <div class="login-container">
        <a href="index.html" class="back-link">← Voltar</a>
        
        <div class="logo">
            <p>Faça login para continuar</p>
        </div>

        <form id="loginForm">
            <div class="form-group">
                <label for="email">Email ou Usuário</label>
                <input type="text" id="email" name="email" required placeholder="Digite seu email ou usuário">
            </div>

            <div class="form-group">
                <label for="password">Senha</label>
                <input type="password" id="password" name="password" required placeholder="Digite sua senha">
            </div>

            <div class="remember-forgot">
                <div class="checkbox-group">
                    <input type="checkbox" id="remember" name="remember">
                    <label for="remember" style="margin: 0;">Lembrar-me</label>
                </div>
                <a href="#"><strong>Esqueceu a senha?</strong></a>
            </div>

            <button type="submit" id="submit-btn" class="login-btn">Entrar</button>
        </form>

        <div class="signup-link">
            Não tem conta? <a href="CadastroCliente.html">Crie uma aqui</a>
        </div>
    </div>


    
</body>
</html>